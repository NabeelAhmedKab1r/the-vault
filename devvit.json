{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "daily-vault",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create Vault post",
        "description": "Create the Vault heist post for this subreddit",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "[DEV ONLY] Reset today's vault",
        "description": "Wipes today's vault + attempts for testing. Only works on the dev test subreddit — remove before a real launch.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/dev-reset-vault"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "daily_vault_dev"
  }
}